# ─── Database ────────────────────────────────────────────
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# ─── API Server ──────────────────────────────────────────
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info
HAGGLE_CORS_ORIGINS=https://tryhaggle.ai

# ─── Supabase ────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[ANON-KEY]
SUPABASE_JWT_SECRET=[SUPABASE-JWT-SECRET]
SUPABASE_SERVICE_ROLE_KEY=[SERVICE-ROLE-KEY]

# ─── x402 Payment (Base + USDC) ──────────────────────────
# mock | real
HAGGLE_X402_MODE=mock
HAGGLE_X402_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402
# base | base-sepolia
HAGGLE_X402_NETWORK=base
HAGGLE_X402_WALLET_NETWORK=eip155:8453
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
HAGGLE_X402_USDC_ASSET_ADDRESS=USDC
HAGGLE_BASE_RPC_URL=
HAGGLE_SETTLEMENT_ROUTER_ADDRESS=
HAGGLE_DISPUTE_REGISTRY_ADDRESS=
HAGGLE_ROUTER_RELAYER_PRIVATE_KEY=
HAGGLE_X402_FEE_BPS=250
HAGGLE_X402_DEFAULT_BUYER_AUTH_MODE=human_wallet
HAGGLE_X402_FEE_WALLET=0xYOUR_HAGGLE_FEE_WALLET
# JSON object: {"seller_id":{"wallet_address":"0x...","network":"eip155:8453","custody":"external"}}
HAGGLE_X402_SELLER_WALLET_MAP={}
# JSON object: {"buyer_id":{"wallet_address":"0x...","network":"eip155:8453","custody":"external"}}
HAGGLE_X402_BUYER_WALLET_MAP={}

# ─── Stripe / Refund / Dispute Deposit Modes ─────────────────
# mock | real
STRIPE_MODE=mock
# mock | usdc | stripe
DEPOSIT_COLLECTION_MODE=mock
# mock | usdc | stripe
REFUND_MODE=mock

# ─── Shipping ────────────────────────────────────────────────
EASYPOST_API_KEY=
EASYPOST_WEBHOOK_SECRET=

# ─── Product Authentication ──────────────────────────────────
LEGITAPP_API_KEY=
LEGITAPP_WEBHOOK_SECRET=
LEGITAPP_BASE_URL=

# ─── Web App ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
