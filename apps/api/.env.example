# ─── Database ────────────────────────────────────────────
# Use Session Pooler URL for IPv4 compatibility
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# ─── Server ──────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=production

# ─── Auth ────────────────────────────────────────────────
# Supabase JWT secret — REQUIRED in production. Found in Supabase dashboard > Settings > API
JWT_SECRET=your-supabase-jwt-secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ─── Public App URL (for share links) ──────────────────
PUBLIC_APP_URL=https://tryhaggle.ai

# ─── Supabase Storage ───────────────────────────────────
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=[SERVICE-ROLE-KEY]

# ─── Payments: Stripe Onramp (fiat → USDC) ──────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe onramp crypto destination wallet
STRIPE_ONRAMP_DESTINATION_WALLET=

# ─── Payments: x402 (Base L2 + USDC) ────────────────────
HAGGLE_X402_MODE=mock
HAGGLE_X402_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402
HAGGLE_X402_NETWORK=base
HAGGLE_X402_WALLET_NETWORK=eip155:8453
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
HAGGLE_X402_USDC_ASSET_ADDRESS=USDC
HAGGLE_BASE_RPC_URL=
HAGGLE_SETTLEMENT_ROUTER_ADDRESS=
HAGGLE_DISPUTE_REGISTRY_ADDRESS=
HAGGLE_ROUTER_RELAYER_PRIVATE_KEY=
HAGGLE_X402_FEE_BPS=250
HAGGLE_X402_DEFAULT_BUYER_AUTH_MODE=human_wallet
HAGGLE_X402_FEE_WALLET=0xYOUR_HAGGLE_FEE_WALLET
HAGGLE_X402_SELLER_WALLET_MAP={}
HAGGLE_X402_BUYER_WALLET_MAP={}

# ─── Webhook Secrets ──────────────────────────────────────
# Generate with: openssl rand -hex 32
HAGGLE_X402_WEBHOOK_SECRET=
EASYPOST_WEBHOOK_SECRET=

# ─── LLM Negotiation Engine ──────────────────────────────
# 'rule' (default, no LLM cost) or 'staged' (LLM-powered)
NEGOTIATION_ENGINE=rule
# xAI API key for Grok 4 Fast
XAI_API_KEY=
XAI_MODEL=grok-4-fast
# Telemetry: '0' disabled, '1' stdout, 'db' stdout + DB persist
LLM_TELEMETRY=0
