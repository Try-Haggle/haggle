# ─── Database ────────────────────────────────────────────
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# ─── Server ──────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

# ─── Public App URL (for share links) ──────────────────
PUBLIC_APP_URL=http://localhost:3000

# ─── Supabase Storage ───────────────────────────────────
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=[SERVICE-ROLE-KEY]

# ─── x402 Payment (Base + USDC) ──────────────────────────
HAGGLE_X402_MODE=mock
HAGGLE_X402_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402
HAGGLE_X402_NETWORK=base
HAGGLE_X402_WALLET_NETWORK=eip155:8453
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
HAGGLE_X402_USDC_ASSET_ADDRESS=USDC
HAGGLE_BASE_RPC_URL=
HAGGLE_SETTLEMENT_ROUTER_ADDRESS=
HAGGLE_DISPUTE_REGISTRY_ADDRESS=
HAGGLE_ROUTER_RELAYER_PRIVATE_KEY=
HAGGLE_X402_FEE_BPS=250
HAGGLE_X402_DEFAULT_BUYER_AUTH_MODE=human_wallet
HAGGLE_X402_FEE_WALLET=0xYOUR_HAGGLE_FEE_WALLET
HAGGLE_X402_SELLER_WALLET_MAP={}
HAGGLE_X402_BUYER_WALLET_MAP={}

# ─── Webhook Secrets ──────────────────────────────────────
# HMAC-SHA256 shared secret for verifying x402 facilitator webhook payloads.
# Required in production. Generate with: openssl rand -hex 32
HAGGLE_X402_WEBHOOK_SECRET=
# HMAC secret for verifying EasyPost webhook payloads.
# Required in production. Set in EasyPost dashboard > Webhooks.
EASYPOST_WEBHOOK_SECRET=

# ─── LLM Negotiation Engine (Step 57) ─────────────────────
# Feature flag: 'rule' (default) or 'llm'
NEGOTIATION_ENGINE=rule
# xAI API key for Grok 4 Fast
XAI_API_KEY=
# Override model (default: grok-4-fast)
XAI_MODEL=grok-4-fast
# LLM telemetry mode:
#   '0'  — disabled (default)
#   '1'  — stdout JSON logging only
#   'db' — stdout JSON logging + persist to llm_telemetry table (requires setTelemetryDb() at startup)
LLM_TELEMETRY=0
